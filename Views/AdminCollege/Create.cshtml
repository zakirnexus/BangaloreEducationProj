@model SchoolProject.Models.Colleges.College
@{
    ViewData["Title"] = "Add New College";
}

<div class="container-fluid py-4">
    <h2>Add New College</h2>

    <form asp-action="Create" method="post" class="row g-3">
        <div class="col-md-6">
            <label class="form-label">College Name *</label>
            <input asp-for="InstituteName" class="form-control" required />
        </div>

        <div class="col-md-6">
            <label class="form-label">Slug (auto-generated)</label>
            <input asp-for="InstituteSlug" class="form-control" readonly placeholder="Will be auto-generated" />
        </div>

        <div class="col-md-6">
            <label class="form-label">City *</label>
            <select asp-for="CityId" class="form-select" required>
                <option value="">Select City</option>
                @foreach (var city in ViewBag.Cities)
                {
                    <option value="@city.CityId">@city.CityName</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label class="form-label">Locality</label>
            <select asp-for="LocalityId" class="form-select">
                <option value="">Select Locality</option>
                @foreach (var loc in ViewBag.Localities)
                {
                    <option value="@loc.LocalityId">@loc.LocalityName</option>
                }
            </select>
        </div>

        <div class="col-md-12">
            <label class="form-label">Address</label>
            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
        </div>

        <div class="col-md-4">
            <label class="form-label">Telephone</label>
            <input asp-for="Telephone" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Mobile</label>
            <input asp-for="Mobile" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Website</label>
            <input asp-for="Website" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Established Year</label>
            <input asp-for="Estd" class="form-control" placeholder="e.g., 1995" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Coed Status</label>
            <select asp-for="CoedId" class="form-select">
                <option value="">Select</option>
                @foreach (var c in ViewBag.Coeds)
                {
                    <option value="@c.CoedId">@c.CoedName</option>
                }
            </select>
        </div>

        <div class="col-md-4">
            <label class="form-label">Ownership</label>
            <select asp-for="InstOwnershipId" class="form-select">
                <option value="">Select</option>
                @foreach (var o in ViewBag.Ownerships)
                {
                    <option value="@o.InstOwnershipId">@o.InstOwnershipType</option>
                }
            </select>
        </div>

        <div class="col-md-4">
            <label class="form-label">NAAC Grade</label>
            <input asp-for="NaacGrade" class="form-control" placeholder="A++, A+, A" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Affiliated To</label>
            <input asp-for="AffiliatedTo" class="form-control" />
        </div>

        <div class="col-md-12">
            <label class="form-label">About Institute</label>
            <textarea asp-for="AboutInstitute" class="form-control" rows="4"></textarea>
        </div>

        <div class="col-md-12">
            <h5 class="mt-3">Facilities</h5>
            <div class="form-check form-check-inline">
                <input asp-for="HostelAvailable" class="form-check-input" />
                <label class="form-check-label">Hostel</label>
            </div>
            <div class="form-check form-check-inline">
                <input asp-for="TransportAvailable" class="form-check-input" />
                <label class="form-check-label">Transport</label>
            </div>
            <div class="form-check form-check-inline">
                <input asp-for="LibraryAvailable" class="form-check-input" />
                <label class="form-check-label">Library</label>
            </div>
            <div class="form-check form-check-inline">
                <input asp-for="SportsFacilities" class="form-check-input" />
                <label class="form-check-label">Sports</label>
            </div>
            <div class="form-check form-check-inline">
                <input asp-for="WifiCampus" class="form-check-input" />
                <label class="form-check-label">WiFi</label>
            </div>
        </div>

        <div class="col-md-12">
            <h5 class="mt-3">Ranking</h5>
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label">Listing Rank (0=regular)</label>
                    <input asp-for="ListingRank" type="number" class="form-control" value="0" />
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input asp-for="IsSponsored" class="form-check-input" />
                        <label class="form-check-label">Sponsored</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input asp-for="IsFeatured" class="form-check-input" />
                        <label class="form-check-label">Featured</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input asp-for="IsActive" class="form-check-input" checked />
                        <label class="form-check-label">Active</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 mt-4">
            <button type="submit" class="btn btn-primary">Create College</button>
            <a href="/AdminCollege" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
