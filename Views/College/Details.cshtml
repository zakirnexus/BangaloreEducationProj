@model SchoolProject.Models.Colleges.College
@{
    ViewData["Title"] = ViewBag.Title;
    var relatedColleges = ViewBag.RelatedColleges as List<SchoolProject.Models.Colleges.College>;
}

@section MetaTags {
    <meta name="description" content="@ViewBag.Description" />
    <link rel="canonical" href="https://www.bangaloreeducation.com@ViewBag.Canonical" />
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/colleges">Colleges</a></li>
            <li class="breadcrumb-item active">@Model.InstituteName</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- Header Card -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-3 text-center">
                            @if (!string.IsNullOrEmpty(Model.Logo))
                            {
                                <img src="@Model.Logo" alt="@Model.InstituteName" class="img-fluid" style="max-height: 120px;" />
                            }
                        </div>
                        <div class="col-md-9">
                            <h1 class="h3">@Model.InstituteName</h1>
                            <p class="text-muted mb-2">
                                <i class="bi bi-geo-alt"></i> @Model.Address, @Model.Locality?.LocalityName, @Model.City?.CityName
                            </p>
                            @if (!string.IsNullOrEmpty(Model.AffiliatedTo))
                            {
                                <p class="mb-1"><strong>Affiliated to:</strong> @Model.AffiliatedTo</p>
                            }
                            @if (!string.IsNullOrEmpty(Model.ApprovedBy))
                            {
                                <p class="mb-1"><strong>Approved by:</strong> @Model.ApprovedBy</p>
                            }
                            <div class="mt-2">
                                @if (Model.NaacGrade != null)
                                {<span class="badge bg-success me-2">NAAC @Model.NaacGrade</span>}
                                @if (Model.NbaAccredited)
                                {<span class="badge bg-info me-2">NBA Accredited</span>}
                                @if (Model.HostelAvailable)
                                {<span class="badge bg-secondary me-2">Hostel</span>}
                                @if (Model.ScholarshipAvailable)
                                {<span class="badge bg-warning text-dark">Scholarship</span>}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Info -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card text-center h-100">
                        <div class="card-body">
                            <h5 class="text-primary">@Model.PlacementPercentage%</h5>
                            <p class="text-muted mb-0">Placement Rate</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center h-100">
                        <div class="card-body">
                            <h5 class="text-primary">₹@Model.AvgPackageLpa LPA</h5>
                            <p class="text-muted mb-0">Avg Package</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center h-100">
                        <div class="card-body">
                            <h5 class="text-primary">@Model.Estd</h5>
                            <p class="text-muted mb-0">Established</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- About -->
            @if (!string.IsNullOrEmpty(Model.AboutInstitute))
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">About @Model.InstituteName</h5>
                    </div>
                    <div class="card-body">
                        @Html.Raw(Model.AboutInstitute)
                    </div>
                </div>
            }

            <!-- Courses Offered -->
            @if (Model.CollegeCourses != null && Model.CollegeCourses.Any())
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Courses Offered</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Course</th>
                                        <th>Specialization</th>
                                        <th>Fees</th>
                                        <th>Duration</th>
                                        <th>Seats</th>
                                        <th>Entrance Exam</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var cc in Model.CollegeCourses!.Where(c => c.IsActive))
                                {
                                    <tr>
                                        <td>@cc.Course?.CourseName</td>
                                        <td>@(string.IsNullOrEmpty(cc.Specialization) ? "-" : cc.Specialization)</td>
                                        <td>@(string.IsNullOrEmpty(cc.FeesStructure) ? "-" : cc.FeesStructure)</td>
                                        <td>@(string.IsNullOrEmpty(cc.CourseDuration) ? "-" : cc.CourseDuration)</td>
                                        <td>@(cc.TotalSeats?.ToString() ?? "-")</td>
                                        <td>@(string.IsNullOrEmpty(cc.EntranceExam) ? "-" : cc.EntranceExam)</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- Facilities -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Facilities</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <i class="bi @(Model.HostelAvailable ? "bi-check-circle text-success" : "bi-x-circle text-danger")"></i> Hostel
                        </div>
                        <div class="col-md-4 mb-2">
                            <i class="bi @(Model.TransportAvailable ? "bi-check-circle text-success" : "bi-x-circle text-danger")"></i> Transport
                        </div>
                        <div class="col-md-4 mb-2">
                            <i class="bi @(Model.LibraryAvailable ? "bi-check-circle text-success" : "bi-x-circle text-danger")"></i> Library
                        </div>
                        <div class="col-md-4 mb-2">
                            <i class="bi @(Model.SportsFacilities ? "bi-check-circle text-success" : "bi-x-circle text-danger")"></i> Sports
                        </div>
                        <div class="col-md-4 mb-2">
                            <i class="bi @(Model.WifiCampus ? "bi-check-circle text-success" : "bi-x-circle text-danger")"></i> WiFi Campus
                        </div>
                    </div>
                </div>
            </div>

            <!-- Placements -->
            @if (Model.PlacementPercentage.HasValue || !string.IsNullOrEmpty(Model.TopRecruiters))
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Placements</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.PlacementPercentage.HasValue)
                        {
                            <p><strong>Placement Percentage:</strong> @Model.PlacementPercentage%</p>
                        }
                        @if (Model.AvgPackageLpa.HasValue)
                        {
                            <p><strong>Average Package:</strong> ₹@Model.AvgPackageLpa LPA</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.TopRecruiters))
                        {
                            <p><strong>Top Recruiters:</strong> @Model.TopRecruiters</p>
                        }
                    </div>
                </div>
            }

            <!-- Contact -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Contact Information</h5>
                </div>
                <div class="card-body">
                    <p><i class="bi bi-geo-alt"></i> @Model.Address, @Model.City?.CityName - @Model.Pincode</p>
                    @if (!string.IsNullOrEmpty(Model.Telephone))
                    {<p><i class="bi bi-telephone"></i> @Model.Telephone</p>}
                    @if (!string.IsNullOrEmpty(Model.Mobile))
                    {<p><i class="bi bi-phone"></i> @Model.Mobile</p>}
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {<p><i class="bi bi-envelope"></i> <a href="mailto:@Model.Email">@Model.Email</a></p>}
                    @if (!string.IsNullOrEmpty(Model.Website))
                    {<p><i class="bi bi-globe"></i> <a href="@Model.Website" target="_blank">@Model.Website</a></p>}
                </div>
            </div>

            <!-- Enquiry CTA -->
            <div class="card bg-primary text-white mb-4">
                <div class="card-body text-center">
                    <h5>Interested in @Model.InstituteName?</h5>
                    <p>Get free admission guidance and fee details</p>
                    <button class="btn btn-light" onclick="openEnquiryModal(@Model.InstituteId, '@Model.InstituteName')">
                        Request Callback
                    </button>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Related Colleges -->
            @if (relatedColleges != null && relatedColleges.Any())
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0">Related Colleges in @Model.City?.CityName</h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            @foreach (var rc in relatedColleges)
                            {
                                <li class="mb-2">
                                    <a href="/college/@rc.InstituteSlug">@rc.InstituteName</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            <!-- Courses -->
            @if (Model.CollegeCourses != null && Model.CollegeCourses.Any())
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h6 class="mb-0">Courses Offered</h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            @foreach (var cc in Model.CollegeCourses.Where(c => c.IsActive).Take(5))
                            {
                                <li class="mb-2">
                                    <a href="/@cc.Course?.CourseSlug-colleges-in-@Model.City?.CitySlug">
                                        @cc.Course?.CourseName
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<partial name="_EnquiryModalCollege" />

@section Scripts {
    <script src="~/js/college-enquiry.js"></script>
}
