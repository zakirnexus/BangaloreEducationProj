@{
    var localities = ViewBag.Localities;
    var nsewcOptions = ViewBag.NsewcOptions;
    var coedOptions = ViewBag.CoedOptions;
    var ownerOptions = ViewBag.OwnerOptions;
    var selLocality = ViewBag.SelLocality;
    var selNsewc = ViewBag.SelNsewc;
    var selCoed = ViewBag.SelCoed;
    var selOwnership = ViewBag.SelOwnership;
    var selFees = ViewBag.SelFees;
}

<div class="card mb-3">
    <div class="card-header">
        <h6 class="mb-0"><i class="bi bi-funnel"></i> Filter Colleges</h6>
    </div>
    <div class="card-body">
        <form method="get" id="collegeFilterForm">
            <!-- Locality -->
            <div class="mb-3">
                <label class="form-label">Locality</label>
                <select name="locality" class="form-select form-select-sm">
                    <option value="">All Localities</option>
                    @if (localities != null)
                    {
                        @foreach (var loc in localities)
                        {
                            <option value="@loc.LocalityId" selected="@(selLocality == loc.LocalityId ? "selected" : null)">@loc.LocalityName</option>
                        }
                    }
                </select>
            </div>

            <!-- Area (NSEWC) -->
            @if (nsewcOptions != null && nsewcOptions.Count > 0)
            {
                <div class="mb-3">
                    <label class="form-label">Area</label>
                    <select name="nsewc" class="form-select form-select-sm">
                        <option value="">All Areas</option>
                        @foreach (var n in nsewcOptions)
                        {
                            <option value="@n" selected="@(selNsewc == n ? "selected" : null)">@n</option>
                        }
                    </select>
                </div>
            }

            <!-- Coed -->
            @if (coedOptions != null && coedOptions.Count > 0)
            {
                <div class="mb-3">
                    <label class="form-label">Gender</label>
                    <select name="coedId" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var c in coedOptions)
                        {
                            <option value="@c.CoedId" selected="@(selCoed == c.CoedId ? "selected" : null)">@c.CoedName</option>
                        }
                    </select>
                </div>
            }

            <!-- Ownership -->
            @if (ownerOptions != null && ownerOptions.Count > 0)
            {
                <div class="mb-3">
                    <label class="form-label">Ownership</label>
                    <select name="ownershipId" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var o in ownerOptions)
                        {
                            <option value="@o.InstOwnershipId" selected="@(selOwnership == o.InstOwnershipId ? "selected" : null)">@o.Type</option>
                        }
                    </select>
                </div>
            }

            <!-- Fees Range -->
            <div class="mb-3">
                <label class="form-label">Fees Range (Annual)</label>
                <select name="feesRange" class="form-select form-select-sm">
                    <option value="">Any</option>
                    <option value="0-50000" selected="@(selFees == "0-50000" ? "selected" : null)">Below ₹50,000</option>
                    <option value="50000-100000" selected="@(selFees == "50000-100000" ? "selected" : null)">₹50,000 - ₹1,00,000</option>
                    <option value="100000-200000" selected="@(selFees == "100000-200000" ? "selected" : null)">₹1,00,000 - ₹2,00,000</option>
                    <option value="200000-500000" selected="@(selFees == "200000-500000" ? "selected" : null)">₹2,00,000 - ₹5,00,000</option>
                    <option value="500000-999999999" selected="@(selFees == "500000-999999999" ? "selected" : null)">Above ₹5,00,000</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary btn-sm w-100">Apply Filters</button>
            @if (ViewBag.FiltersActive == true)
            {
                <a href="/@ViewBag.Course-colleges-in-@ViewBag.City" class="btn btn-outline-secondary btn-sm w-100 mt-2">Clear All</a>
            }
        </form>
    </div>
</div>
